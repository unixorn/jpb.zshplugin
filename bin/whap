#!/usr/bin/env python3

"""This small script offers a python equivalent to "which"

For every argument on the command line it lists
    all python files and all directories with that name
    in each of the directories in sys.path

If a name is found more than once each is listed
    (but python will only import one, probably the first listed)
"""

_copyright = """
(c) J Alan Brogan 2013
    The source is released under the MIT license
    See http://jalanb.mit-license.org/ for more information
"""


import fnmatch
import importlib
import os
import sys
from typing import List, Optional, Sequence


def directory_list(path: str) -> List[str]:
    """Return a list of names in a directory.

    Args:
        path: Path to inspect.

    Returns:
        A list of entries in the directory, or an empty list if the path is not a directory.
    """
    if not os.path.isdir(path):
        return []
    return os.listdir(path)


def is_file_in(path: str, name: str) -> bool:
    """Return whether a name is a file at the given path."""
    path_to_name = os.path.join(path, name)
    return os.path.isfile(path_to_name)


def is_matching_file_in(path: str, name: str, glob: str) -> bool:
    """Return whether the name is a file in the path and matches the glob."""
    return is_file_in(path, name) and fnmatch.fnmatch(name, glob)


def path_to_module(path: str, name: str) -> Optional[str]:
    """Return the path to a Python module file in a directory.

    Args:
        path: Directory path to search.
        name: Module name to look for.

    Returns:
        The path to the matching Python source or compiled file, or None if none found.
    """
    glob = '%s.py*' % name
    python_files = [f
                    for f in directory_list(path)
                    if is_matching_file_in(path, f, glob)]
    if not python_files:
        return None
    source_files = [f for f in python_files if os.path.splitext(f)[-1] == '.py']
    python_file = source_files[0] if source_files else python_files[0]
    return os.path.join(path, python_file)


def path_to_sub_directory(path: str, name: str) -> Optional[str]:
    """Return a sub-directory path if it exists."""
    result = os.path.join(path, name)
    if os.path.isdir(result):
        return result
    return None


def path_to_python(path: str, name: str) -> Optional[str]:
    """Return either a sub-directory or module path for a given name."""
    result = path_to_sub_directory(path, name)
    if result:
        return result
    return path_to_module(path, name)


def built_in(name: str) -> bool:
    """Return whether the given name is a built-in Python module."""
    try:
        # Not all builtin modules are initially imported, so bring it in first.
        __import__(name)
    except ImportError:
        return False
    return '(built-in)' in str(sys.modules[name])


def path_to_import(module_name: str) -> Optional[str]:
    """Return the file path for an imported module.

    Args:
        module_name: The module name to import.

    Returns:
        The path to the imported module, or None if unavailable.
    """
    module = importlib.import_module(module_name)
    if module:
        path_to_file = getattr(module, '__file__', None)
        if path_to_file is None:
            return None
        if '.egg/' in path_to_file:
            return path_to_file.split('.egg/')[0] + '.egg'
        return path_to_file
    return None


def main(strings: Sequence[str]) -> int:
    """Run the program for the provided arguments.

    Args:
        strings: Module or package names to locate.

    Returns:
        Exit status code.
    """
    for string in strings:
        if built_in(string):
            print('builtin', string)
        path_to_imported_module = path_to_import(string)
        if path_to_imported_module:
            os.system('ls -ld %s' % path_to_imported_module)
    return 0


if __name__ == '__main__':
    args = sys.argv[1:]
    if not args:
        from what import test
        sys.exit(test())
    else:
        sys.exit(main(args))
