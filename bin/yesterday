#!/usr/bin/env python3
#
# Original source
# https://github.com/ClarkGoble/Scripts/blob/master/yesterday.py
###############################
#   yesterday.py
###############################
#
# Types yesterday's date formatted

import datetime
import string
import sys
from typing import Optional, Sequence

try:
    from appscript import app, k  # type: ignore[import]
except ImportError:
    pass


def getdate() -> str:
    """Return yesterday's date formatted as MM/DD/YYYY."""
    d = datetime.date.today()
    d = d + datetime.timedelta(-1)
    return d.strftime("%m/%d/%Y")


def typestring(s: str) -> None:
    """Type the provided string using macOS System Events.

    Args:
        s: The string to type.
    """
    SE = app("System Events")

    for c in s:
        if c == "\n":
            continue

        if c in string.ascii_uppercase:
            SE.keystroke(c, using=k.shift_down)
        else:
            SE.keystroke(c)


def main(argv: Optional[Sequence[str]] = None) -> int:
    """Main entry point for the script.

    Args:
        argv: Ignored command-line arguments.

    Returns:
        Exit status code.
    """
    print(getdate())
    return 0


if __name__ == "__main__":
    sys.exit(main())
